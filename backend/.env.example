# Backend Environment Configuration Example
PORT=8080
DB_URL=jdbc:mysql://127.0.0.1:3306/kings_tv_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&useUnicode=true&characterEncoding=UTF-8
DB_USER=root
DB_PASSWORD=root
